* {
    font-family: 'GG Sans', 'Vazirmatn' !important;
}

*[aria-label="Direct Messages"] a[href="/store"],
button[aria-label="Send a gift"],
button[aria-label="Open sticker picker"],
button[aria-label="Apps"][tabindex="0"],
*[aria-label^="Click to react with"],
a[href="https://support.discord.com"],
a[href="/shop"] {
    display: none;
}
